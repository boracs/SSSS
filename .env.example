APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Madrid
# Reloj de pared de la escuela para starts_at/ends_at (si no se define, Europe/Madrid)
# ACADEMY_BUSINESS_TIMEZONE=Europe/Madrid
# WhatsApp de la escuela (solo dígitos, ej. 34600111222). Opcional: texto visible en plantillas/UI.
# ACADEMY_WHATSAPP_NUMBER=34600111222
# ACADEMY_WHATSAPP_DISPLAY=+34 600 11 12 22
# Email de contacto público (chatbot FAQ, marketing). Por defecto info@sansebastiansurfschool.com
# ACADEMY_CONTACT_EMAIL=info@sansebastiansurfschool.com
# Logística chatbot / Gemini (texto libre; ajustar en producción)
# ACADEMY_LOCATION_LABEL=Playa de Zurriola, Donostia — instalaciones del club
# ACADEMY_OPENING_HOURS=Lunes a domingo 9:00–20:00 (ejemplo)
# ACADEMY_GETTING_HERE=Llega 10–15 min antes; punto de encuentro en Zurriola junto al club.
# ACADEMY_INSTAGRAM_HANDLE=@sansebastiansurfschool
# Chatbot — Gemini (FAQ local como capa primaria; Gemini solo si el FAQ no entiende).
# No subas una clave real al repositorio; cópiala solo en tu .env local.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# Contacto directo Edy Mulder (reparación de tablas)
# REPAIR_EDY_NAME=Edy Mulder
# REPAIR_EDY_PHONE=34600123456
# REPAIR_EDY_PHONE_DISPLAY=+34 600 12 34 56
# REPAIR_EDY_EMAIL=edy.mulder@ejemplo.com
# Contacto Willy (reparación de neoprenos)
# REPAIR_WILLY_NAME=Willy
# REPAIR_WILLY_PHONE=34600987654
# REPAIR_WILLY_PHONE_DISPLAY=+34 600 98 76 54
# REPAIR_WILLY_EMAIL=willy@ejemplo.com
APP_URL=http://localhost
# Al compartir con Dev Tunnels, usa la URL pública en APP_URL (sin barra final):
# APP_URL=https://TU-ID-8000.region.devtunnels.ms
# TUNNEL_SHARE=true
# (No uses ASSET_URL con el túnel; provoca ERR_CERT_AUTHORITY_INVALID en assets.)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mas_que_surf
DB_USERNAME=root
DB_PASSWORD=

# Opcional: alinea NOW() de MySQL con la escuela (requiere tablas de zona en MySQL). Si falla la conexión, déjalo comentado.
# DB_TIMEZONE=Europe/Madrid

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
CONTACT_FORM_TO="hello@example.com"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Stripe (pasarela de pagos) ────────────────────────────────────────────
# Claves: https://dashboard.stripe.com/apikeys (TEST en local, LIVE en producción)
STRIPE_KEY=
STRIPE_SECRET=
# Webhook signing secret (whsec_…). Producción: Dashboard → Webhooks → endpoint /webhooks/stripe
# Local: stripe listen --forward-to http://127.0.0.1:8000/webhooks/stripe
# Ver docs/payments/STRIPE-WEBHOOK.md
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=eur

# ── Facturación fiscal: TicketBAI vía B2BRouter ──────────────────────────
# Kill-switch global (false = ningún Job/llamada HTTP; el cobro Stripe no se ve afectado).
INVOICING_ENABLED=false
INVOICING_DRIVER=b2brouter
# Sandbox (recomendado, gratis e inmediato) y Producción usan la MISMA url;
# lo que cambia es el prefijo de la API key (test_... = sandbox, prod_... = producción).
# Solo usa https://api-staging.b2brouter.net si te han dado acceso a Staging (ticket de soporte).
B2BROUTER_BASE_URL=https://api.b2brouter.net
# API key de la cuenta B2BRouter (Developers → Sandbox → Claves API). No subas la clave real al repo.
B2BROUTER_API_KEY=
B2BROUTER_API_VERSION=2025-10-13
# ID numérico de la cuenta B2BRouter (POST /accounts/{ACCOUNT_ID}/invoices)
B2BROUTER_ACCOUNT_ID=
# Informativo: la delegación foral real se configura en tax_report_settings de la cuenta B2B.
B2BROUTER_DELEGATION=gipuzkoa
# B2BROUTER_HTTP_TIMEOUT=15
# INVOICING_DEFAULT_VAT_PERCENT=21
# INVOICING_DEFAULT_VAT_CATEGORY=S
# INVOICING_POLL_MAX_ATTEMPTS=8

# ── AutoCoach (comparador de maniobras / comparador-surf) ──
# Minutos antes de borrar subidas temporales (cron cada 5 min).
AUTOCOACH_UPLOAD_TTL_MINUTES=30
# Máximo de vídeos por petición de subida.
AUTOCOACH_MAX_FILES_PER_BATCH=10
# Tamaño máximo por clip en bytes (25 MB = 26214400).
AUTOCOACH_MAX_FILE_BYTES=26214400
# Almacenamiento máximo por sesión de visitante en bytes (120 MB).
AUTOCOACH_MAX_SESSION_BYTES=125829120
# Límite global de disco para todas las subidas temporales (2 GB).
AUTOCOACH_MAX_TOTAL_UPLOAD_BYTES=2147483648
# Subidas permitidas por IP en la ventana temporal.
AUTOCOACH_IP_UPLOAD_QUOTA=40
# Ventana de cuota por IP (minutos).
AUTOCOACH_IP_QUOTA_WINDOW_MINUTES=5
# Cookie de sesión solo por HTTPS (true en producción).
AUTOCOACH_COOKIE_SECURE=false
# Ruta opcional con vídeos de referencia para `php artisan autocoach:sync-reference-videos` (solo instalaciones nuevas).
# AUTOCOACH_REFERENCE_VIDEOS_SOURCE=
